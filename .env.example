# ============================================================
# VW Classic Club — Shopify App Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- SHOPIFY APP CREDENTIALS ---
# Found in your Shopify Partners dashboard under "App Setup"
SHOPIFY_API_KEY=your_shopify_client_id_here
SHOPIFY_API_SECRET=shpss_your_shopify_client_secret_here

# --- SHOPIFY APP SCOPES ---
SCOPES=write_products,read_products,write_inventory,read_inventory,write_shipping,read_shipping,read_files,write_files,write_orders,read_orders

# --- APP HOST (Public URL) ---
# Development: Use your Cloudflare Tunnel or ngrok URL (no trailing slash)
# Example (ngrok):          HOST=https://abc123.ngrok-free.app
# Example (CF Tunnel):      HOST=https://vwclassic.yourdomain.com
# Production (Docker/VPS):  HOST=https://your-vps-domain.com
HOST=https://your-tunnel-or-domain.com

# --- SHOPIFY STORE DOMAIN ---
# Your myshopify.com store domain
SHOPIFY_SHOP=your-store.myshopify.com

# --- SESSION / DATABASE ---
# SQLite database file path (relative to project root)
DATABASE_URL="file:./dev.db"

# --- GOOGLE GEMINI AI ---
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- STORE SETTINGS ---
STORE_CURRENCY=USD

# --- CUSTOMS / LOGISTICS ---
# Your unique Manufacturer Identification Code for customs proformas
MANUFACTURER_MID_CODE=TREOZETOIST34755

# --- SERVER ---
PORT=3000
NODE_ENV=development

# --- WEBHOOK SECRET ---
# Used to verify incoming Shopify webhook HMAC signatures
# Set this to the same value as SHOPIFY_API_SECRET for simplicity,
# or generate a separate random string
SHOPIFY_WEBHOOK_SECRET=shpss_your_shopify_client_secret_here

# --- RATE LIMITING ---
# Max API calls per second (Shopify default bucket = 1000 points)
GRAPHQL_THROTTLE_MS=500
